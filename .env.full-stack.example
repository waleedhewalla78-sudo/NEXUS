# Full-stack compose environment (repo root)
# Copy to .env.full-stack and customize before: docker compose --env-file .env.full-stack -f docker-compose.full-stack.yml up

# ------- Nexus app (required) -------
APP_PORT=3005
NEXUS_ENV_FILE=./nexus-social-app/.env
PUBLISHING_ENABLED=true
ANALYTICS_SYNC_ENABLED=true
SYNC_ANALYTICS_INTERVAL_MS=21600000
TOKEN_REFRESH_ENABLED=true
TOKEN_REFRESH_INTERVAL_MS=3600000

# Supabase (external — set in nexus-social-app/.env)
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# TOKEN_ENCRYPTION_KEY=

# ------- Chatwoot (optional — profile: integrations) -------
CHATWOOT_PORT=3003
CHATWOOT_POSTGRES_PASSWORD=chatwoot
CHATWOOT_SECRET_KEY_BASE=replace-with-long-random-string-min-64-chars

# ------- Dify (optional — profile: integrations) -------
DIFY_API_PORT=5001
DIFY_POSTGRES_PASSWORD=difyai123456
DIFY_SECRET_KEY=replace-with-dify-secret-key

# ------- Activepieces (optional — profile: integrations) -------
ACTIVEPIECES_PORT=8080
AP_POSTGRES_USERNAME=postgres
AP_POSTGRES_PASSWORD=activepieces
AP_POSTGRES_DATABASE=activepieces
AP_ENCRYPTION_KEY=replace-with-32-character-key!!
AP_JWT_SECRET=replace-with-jwt-secret
AP_WEBHOOK_ID=replace-me

# Internal URLs (used inside nexus-web / nexus-worker containers)
# CHATWOOT_BASE_URL=http://chatwoot-rails:3000
# DIFY_BASE_URL=http://dify-api:5001
# ACTIVEPIECES_BASE_URL=http://activepieces:80
