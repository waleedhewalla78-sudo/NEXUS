# ==============================================================
# .env.example – Nexus Social Platform
# ==============================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
# ==============================================================

# ------- Supabase -------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# Direct Postgres URI for psql / npm run db:migrate:local (Settings → Database → URI, ends /postgres)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ------- Inngest (orchestration — required in production) -------
INNGEST_SIGNING_KEY=signkey-local-dev-only-change-in-prod
INNGEST_EVENT_KEY=local
# Set INNGEST_DEV=1 only for local dev server against Inngest Dev Server
INNGEST_DEV=1

# ------- Redis (AI queue + API rate limits) -------
REDIS_URL=redis://localhost:6379

# ------- Workspace (dev fallbacks only) -------
NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=your-workspace-uuid
NEXT_PUBLIC_USER_ID=your-user-uuid

# ------- Chatwoot -------
CHATWOOT_API_TOKEN=your_chatwoot_api_token
CHATWOOT_ACCOUNT_ID=your_account_id
CHATWOOT_WEBHOOK_SECRET=your_chatwoot_webhook_hmac_secret
# In production, use the internal Docker service name (e.g., http://chatwoot:3000)
CHATWOOT_BASE_URL=http://localhost:3003

# ------- OpenRouter (optional AI fallback) -------
# OpenAI-compatible API used when Dify is unavailable. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key

# ------- Dify (AI) -------
# Cloud: https://api.dify.ai  |  Self-hosted: your Dify server URL (no trailing slash)
DIFY_BASE_URL=https://api.dify.ai
DIFY_API_KEY=app-your-dify-app-api-key
DIFY_APP_ID=
DIFY_DATASET_ID=
# Optional: provision new apps per workspace via API
DIFY_ADMIN_API_KEY=

# ------- Activepieces (Automation) -------
# In production, use the internal Docker service name (e.g., http://activepieces:8080/api/v1/webhooks/...)
ACTIVEPIECES_WEBHOOK_URL=http://localhost:3004/webhook
ACTIVEPIECES_BASE_URL=http://localhost:8080

# ------- Stripe (Billing) -------
STRIPE_SECRET_KEY=sk_test_your_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key

# ------- Security / Internal (REQUIRED in production) -------
INTERNAL_TOOL_SECRET=generate-a-long-random-string-min-32-chars
APPROVAL_HMAC_SECRET=generate-another-long-random-string-min-32-chars
CHATWOOT_WEBHOOK_SECRET=your_chatwoot_webhook_hmac_secret
JWT_SECRET=optional-jwt-secret-for-legacy-tokens
CRON_SECRET=secret-for-vercel-cron-ai-eval

# ------- CRM Reverse ETL (optional) -------
CRM_WEBHOOK_URL=https://your-crm-endpoint.example/webhook
# HubSpot inbound webhook (POST /api/integrations/crm/webhook/hubspot?workspaceId=...)
HUBSPOT_WEBHOOK_SECRET=your-hubspot-app-client-secret
HUBSPOT_WEBHOOK_WORKSPACE_ID=your-workspace-uuid
HUBSPOT_ACCESS_TOKEN=your-hubspot-private-app-token
HUBSPOT_CLIENT_ID=your-hubspot-oauth-app-client-id
HUBSPOT_CLIENT_SECRET=your-hubspot-oauth-app-client-secret
HUBSPOT_OAUTH_REDIRECT_URI=http://localhost:3005/api/oauth/hubspot/callback
SALESFORCE_WEBHOOK_SECRET=your-salesforce-webhook-secret
SALESFORCE_WEBHOOK_WORKSPACE_ID=your-workspace-uuid

# ------- Shopify (optional — enables real order lookup tool) -------
SHOPIFY_STORE_URL=https://your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_your_token

# ------- Publishing (Epic 1) -------
# Register OAuth apps at each developer portal, then paste credentials below.
# Redirect URIs (local dev port 3005):
#   LinkedIn: http://localhost:3005/api/oauth/linkedin/callback
#   X:        http://localhost:3005/api/oauth/x/callback
#   Meta:     http://localhost:3005/api/oauth/meta/callback
# Production: replace localhost:3005 with your NEXT_PUBLIC_APP_URL host.
# 32-byte key for AES-256-GCM token encryption (generate: openssl rand -hex 32)
TOKEN_ENCRYPTION_KEY=
PUBLISHING_ENABLED=true
PUBLISH_INTERVAL_MS=60000
META_APP_ID=
META_APP_SECRET=
META_OAUTH_REDIRECT_URI=http://localhost:3005/api/oauth/meta/callback
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:3005/api/oauth/linkedin/callback
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=http://localhost:3005/api/oauth/x/callback
SYNC_ANALYTICS_INTERVAL_MS=21600000
ANALYTICS_SYNC_ENABLED=true
TOKEN_REFRESH_ENABLED=true
TOKEN_REFRESH_INTERVAL_MS=3600000
TOKEN_REFRESH_WINDOW_HOURS=48
REPUTATION_SYNC_ENABLED=true
REPUTATION_SYNC_INTERVAL_MS=3600000
RAG_INGEST_ENABLED=true
RAG_INGEST_INTERVAL_MS=21600000
# Dev-only demo analytics (never used in production)
DEMO_ANALYTICS_ENABLED=false

# ------- Facebook Page publishing (optional — scripts/publish-facebook-post.ts) -------
# Numeric Page ID from Meta (NOT a facebook.com/share/p/… link). Find via Graph API Explorer:
#   GET /me/accounts  →  use the "id" field for your Page
FACEBOOK_PAGE_ID=123456789012345
# Page access token with pages_manage_posts (and pages_read_engagement). From /me/accounts or Business Manager.
FACEBOOK_PAGE_ACCESS_TOKEN=
# Optional: Graph API version (default v21.0)
# FACEBOOK_GRAPH_API_VERSION=v21.0
# Optional: default post UUID for npm run facebook:publish
# FACEBOOK_PUBLISH_POST_ID=e0d9da20-97b6-49bb-af33-36ef4f714aab

# ------- Feature flags (Sprint 2) -------
# SaaS dashboard chrome (workspace switcher, full sidebar, SaaS settings)
NEXT_PUBLIC_ENABLE_SaaS_UI=false
# Public enterprise landing page at /enterprise
NEXT_PUBLIC_ENABLE_ENTERPRISE_LANDING=true

# ------- Enterprise SSO (optional) -------
NEXT_PUBLIC_SAML_ENABLED=false

# ------- App URL (invites, password reset redirects) -------
# Local dev uses reserved port 3005 (see scripts/dev-port.ps1) to avoid 3000 conflicts.
DEV_PORT=3005
NEXT_PUBLIC_APP_URL=http://localhost:3005

# ------- Walkthrough / E2E testing -------
WALKTHROUGH_USER_ID=your-auth-user-uuid
CYPRESS_TEST_EMAIL=test@example.com
CYPRESS_TEST_PASSWORD=your-test-password

# ------- Observability (optional) -------
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
AI_CMO_MV_REFRESH_ENABLED=true
AI_CMO_MV_REFRESH_INTERVAL_MS=3600000

# ------- Production / Docker -------
APP_PORT=3000
NODE_ENV=development
