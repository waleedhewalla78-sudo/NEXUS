# ==============================================================
# .env.production.template — Nexus Social Platform (PRODUCTION)
# ==============================================================
# Copy to your secrets manager / hosting provider env — NEVER commit filled values.
# Replace every ${PLACEHOLDER} with real production values.
# Source: verify-env.ts PRODUCTION_REQUIRED + integration inventory (2026-07-03)
# ==============================================================

# ------- App -------
NODE_ENV=production
# Public URL of the deployed app (OAuth redirects, webhooks, invites)
NEXT_PUBLIC_APP_URL=${PROD_APP_URL}
APP_PORT=3000

# ------- Supabase (Settings → API) -------
NEXT_PUBLIC_SUPABASE_URL=${PROD_SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${PROD_SUPABASE_ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${PROD_SUPABASE_SERVICE_ROLE_KEY}
# Direct Postgres URI for migrations/psql (Settings → Database → Connection string → URI, ends /postgres)
DATABASE_URL=${PROD_DATABASE_URL}

# ------- Redis (required: publish queue, rate limits, jobs) -------
# PROD CONSTRAINT: Use Upstash (cloud). DO NOT use localhost Redis on the 8GB VPS.
REDIS_URL=${PROD_REDIS_URL}

# ------- Inngest Cloud (https://app.inngest.com → your app → Signing Key + Event Key) -------
INNGEST_SIGNING_KEY=${PROD_INNGEST_SIGNING_KEY}
INNGEST_EVENT_KEY=${PROD_INNGEST_EVENT_KEY}
# Do NOT set INNGEST_DEV=1 in production

# ------- Dify AI (https://cloud.dify.ai → app → Publish → API Access) -------
DIFY_BASE_URL=https://api.dify.ai
DIFY_API_KEY=${PROD_DIFY_API_KEY}
DIFY_APP_ID=${PROD_DIFY_APP_ID}
DIFY_DATASET_ID=${PROD_DIFY_DATASET_ID}
DIFY_ADMIN_API_KEY=${PROD_DIFY_ADMIN_API_KEY}

# ------- OpenRouter (fallback when Dify circuit opens) -------
OPENROUTER_API_KEY=${PROD_OPENROUTER_API_KEY}

# DISABLED: Ollama is banned in production to save RAM. Use CLAUDE_API_KEY or OPENROUTER_API_KEY.

# ------- Security / Internal (REQUIRED — openssl rand -hex 32) -------
INTERNAL_TOOL_SECRET=${PROD_INTERNAL_TOOL_SECRET}
APPROVAL_HMAC_SECRET=${PROD_APPROVAL_HMAC_SECRET}
CHATWOOT_WEBHOOK_SECRET=${PROD_CHATWOOT_WEBHOOK_SECRET}
CRON_SECRET=${PROD_CRON_SECRET}
JWT_SECRET=${PROD_JWT_SECRET}

# ------- Stripe (Billing webhooks) -------
STRIPE_SECRET_KEY=${PROD_STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${PROD_STRIPE_WEBHOOK_SECRET}
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${PROD_STRIPE_PUBLISHABLE_KEY}

# ------- Publishing OAuth (tokens stored per-workspace in workspace_social_connections) -------
PUBLISHING_ENABLED=true
TOKEN_ENCRYPTION_KEY=${PROD_TOKEN_ENCRYPTION_KEY}
META_APP_ID=${PROD_META_APP_ID}
META_APP_SECRET=${PROD_META_APP_SECRET}
META_OAUTH_REDIRECT_URI=${PROD_APP_URL}/api/oauth/meta/callback
LINKEDIN_CLIENT_ID=${PROD_LINKEDIN_CLIENT_ID}
LINKEDIN_CLIENT_SECRET=${PROD_LINKEDIN_CLIENT_SECRET}
LINKEDIN_OAUTH_REDIRECT_URI=${PROD_APP_URL}/api/oauth/linkedin/callback
X_CLIENT_ID=${PROD_X_CLIENT_ID}
X_CLIENT_SECRET=${PROD_X_CLIENT_SECRET}
X_OAUTH_REDIRECT_URI=${PROD_APP_URL}/api/oauth/x/callback

# ------- HubSpot CRM (inbound webhook + optional batch sync) -------
HUBSPOT_WEBHOOK_SECRET=${PROD_HUBSPOT_WEBHOOK_SECRET}
HUBSPOT_WEBHOOK_WORKSPACE_ID=${PROD_WORKSPACE_UUID}
HUBSPOT_ACCESS_TOKEN=${PROD_HUBSPOT_PRIVATE_APP_TOKEN}
HUBSPOT_CLIENT_ID=${PROD_HUBSPOT_CLIENT_ID}
HUBSPOT_CLIENT_SECRET=${PROD_HUBSPOT_CLIENT_SECRET}
HUBSPOT_OAUTH_REDIRECT_URI=${PROD_APP_URL}/api/oauth/hubspot/callback

# ------- Salesforce CRM (inbound webhook) -------
SALESFORCE_WEBHOOK_SECRET=${PROD_SALESFORCE_WEBHOOK_SECRET}
SALESFORCE_WEBHOOK_WORKSPACE_ID=${PROD_WORKSPACE_UUID}

# ------- CRM reverse ETL (optional outbound to customer CRM endpoint) -------
CRM_WEBHOOK_URL=${PROD_CRM_WEBHOOK_URL}

# ------- Chatwoot (Unified Inbox AI) -------
CHATWOOT_BASE_URL=${PROD_CHATWOOT_BASE_URL}
CHATWOOT_API_TOKEN=${PROD_CHATWOOT_API_TOKEN}
CHATWOOT_ACCOUNT_ID=${PROD_CHATWOOT_ACCOUNT_ID}

# ------- Activepieces (optional automation) -------
ACTIVEPIECES_WEBHOOK_URL=${PROD_ACTIVEPIECES_WEBHOOK_URL}
ACTIVEPIECES_BASE_URL=${PROD_ACTIVEPIECES_BASE_URL}

# ------- Qdrant (optional hybrid memory — PG fallback if unset) -------
QDRANT_URL=${PROD_QDRANT_URL}
QDRANT_API_KEY=${PROD_QDRANT_API_KEY}

# ------- Observability (optional until A-GATE-002 resolved) -------
SENTRY_DSN=${PROD_SENTRY_DSN}
NEXT_PUBLIC_SENTRY_DSN=${PROD_SENTRY_DSN}
OTEL_EXPORTER_OTLP_ENDPOINT=${PROD_OTEL_EXPORTER_OTLP_ENDPOINT}

# ------- Worker intervals (production defaults) -------
PUBLISH_INTERVAL_MS=60000
SYNC_ANALYTICS_INTERVAL_MS=21600000
ANALYTICS_SYNC_ENABLED=true
TOKEN_REFRESH_ENABLED=true
AI_CMO_MV_REFRESH_ENABLED=true

# ------- Production safety -------
DEMO_ANALYTICS_ENABLED=false
NEXT_PUBLIC_SAML_ENABLED=false

# ------- Feature flags (Sprint 2) -------
NEXT_PUBLIC_ENABLE_SaaS_UI=false
NEXT_PUBLIC_ENABLE_ENTERPRISE_LANDING=true

# ------- Default workspace (single-tenant prod bootstrap only — prefer per-request scoping) -------
# NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=${PROD_WORKSPACE_UUID}
