# ==============================================================
# .env.production.template — Nexus Social Platform (PRODUCTION)
# ==============================================================
# Copy to .env.production on Hermes VPS. NEVER commit filled values.
# Checklist: docs/OPS-PROD-SECRETS-CHECKLIST.md
# Gate verify: npm run verify:phase-d
# ==============================================================

NODE_ENV=production
APP_PORT=3000
NEXT_PUBLIC_APP_URL=https://nexussocial.tech

# ------- Enterprise skin (Sprint 2) -------
NEXT_PUBLIC_ENABLE_SaaS_UI=false
NEXT_PUBLIC_ENABLE_ENTERPRISE_LANDING=true

# ------- Supabase (prod project only) -------
NEXT_PUBLIC_SUPABASE_URL=${PROD_SUPABASE_URL}
NEXT_PUBLIC_SUPABASE_ANON_KEY=${PROD_SUPABASE_ANON_KEY}
SUPABASE_SERVICE_ROLE_KEY=${PROD_SUPABASE_SERVICE_ROLE_KEY}
DATABASE_URL=${PROD_DATABASE_URL}

# ------- Redis (Upstash TLS — not localhost on VPS) -------
REDIS_URL=${PROD_REDIS_URL}

# ------- Inngest Cloud (required for AI CMO workflows) -------
INNGEST_SIGNING_KEY=${PROD_INNGEST_SIGNING_KEY}
INNGEST_EVENT_KEY=${PROD_INNGEST_EVENT_KEY}
# Do NOT set INNGEST_DEV in production

# ------- LLM providers (production: Dify primary, OpenRouter fallback) -------
USE_LOCAL_OLLAMA=false
OLLAMA_ONLY=false
DIFY_BASE_URL=https://api.dify.ai
DIFY_API_KEY=${PROD_DIFY_API_KEY}
OPENROUTER_API_KEY=${PROD_OPENROUTER_API_KEY}
OPENROUTER_MODEL=openai/gpt-4o-mini

# ------- Security (generate: openssl rand -hex 32) -------
INTERNAL_TOOL_SECRET=${PROD_INTERNAL_TOOL_SECRET}
TOKEN_ENCRYPTION_KEY=${PROD_TOKEN_ENCRYPTION_KEY}
APPROVAL_HMAC_SECRET=${PROD_APPROVAL_HMAC_SECRET}
CHATWOOT_WEBHOOK_SECRET=${PROD_CHATWOOT_WEBHOOK_SECRET}

# ------- NextAuth / SSO -------
NEXTAUTH_URL=https://nexussocial.tech
NEXTAUTH_SECRET=${PROD_NEXTAUTH_SECRET}

# ------- Social OAuth (register redirect URIs in each developer portal) -------
META_APP_ID=${PROD_META_APP_ID}
META_APP_SECRET=${PROD_META_APP_SECRET}
META_OAUTH_REDIRECT_URI=https://nexussocial.tech/api/oauth/meta/callback
LINKEDIN_CLIENT_ID=${PROD_LINKEDIN_CLIENT_ID}
LINKEDIN_CLIENT_SECRET=${PROD_LINKEDIN_CLIENT_SECRET}
LINKEDIN_OAUTH_REDIRECT_URI=https://nexussocial.tech/api/oauth/linkedin/callback
X_CLIENT_ID=${PROD_X_CLIENT_ID}
X_CLIENT_SECRET=${PROD_X_CLIENT_SECRET}
X_OAUTH_REDIRECT_URI=https://nexussocial.tech/api/oauth/x/callback

# Meta Lead Ads webhook (ingest only — no App Review)
META_WEBHOOK_SECRET=${PROD_META_WEBHOOK_SECRET}
META_WEBHOOK_VERIFY_TOKEN=${PROD_META_WEBHOOK_VERIFY_TOKEN}

# ------- Publishing worker -------
PUBLISHING_ENABLED=true
PUBLISH_INTERVAL_MS=60000
ANALYTICS_SYNC_ENABLED=true
TOKEN_REFRESH_ENABLED=true
DEMO_ANALYTICS_ENABLED=false

# ------- CRM (optional) -------
HUBSPOT_CLIENT_ID=${PROD_HUBSPOT_CLIENT_ID}
HUBSPOT_CLIENT_SECRET=${PROD_HUBSPOT_CLIENT_SECRET}
HUBSPOT_OAUTH_REDIRECT_URI=https://nexussocial.tech/api/oauth/hubspot/callback

# ------- Observability (optional) -------
SENTRY_DSN=${PROD_SENTRY_DSN}
SENTRY_ENVIRONMENT=production
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318

# ------- Default workspace (enterprise leads + intelligence) -------
NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=${PROD_DEFAULT_WORKSPACE_ID}
ENTERPRISE_LEADS_WORKSPACE_ID=${PROD_DEFAULT_WORKSPACE_ID}
