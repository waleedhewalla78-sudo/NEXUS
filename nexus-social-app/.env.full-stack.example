# ==============================================================
# .env.full-stack.example — Nexus Social V2.0 Enterprise GA
# ==============================================================
# Ultimate local full-stack template (V1.0 Inngest/Redis + V2.0 Qdrant/NextAuth).
# Copy to .env.local and fill secrets:
#   cp .env.full-stack.example .env.local
# Bootstrap: npm run bootstrap:local
# Verify:    npm run verify:v2-stack
# ==============================================================

# ------- Supabase (remote project or local `supabase start`) -------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
# For psql migration apply (optional — same DB as Supabase project):
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# ------- Redis (003 event bus + 004 rate limits) -------
REDIS_URL=redis://localhost:6379

# ------- Qdrant (V2.0 vector memory + knowledge hub) -------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=ws_

# ------- Embeddings via OpenRouter (text-embedding-ada-002) -------
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ------- Local LLM backbone (Ollama — all agents + Copilot) -------
USE_LOCAL_OLLAMA=true
OLLAMA_ONLY=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=180000
# Per-agent overrides (pull with: ollama pull <name>)
OLLAMA_MODEL_STRATEGIC_BRAIN=llama3.1:8b
OLLAMA_MODEL_CREATOR=llama3.1:8b
OLLAMA_MODEL_QUALITY_JUDGE=llama3.1:8b
OLLAMA_MODEL_OPTIMIZER=llama3.2
OLLAMA_MODEL_RADAR=llama3.2
OLLAMA_MODEL_QUANT=llama3.2
OLLAMA_MODEL_SENTINEL=llama3.2
OLLAMA_MODEL_FINANCE=llama3.2
OLLAMA_MODEL_COMPLIANCE=llama3.1:8b
OLLAMA_MODEL_INBOX=llama3.1:8b
OLLAMA_MODEL_COPILOT=llama3.1:8b
OLLAMA_MODEL_CAPTION=llama3.2
OLLAMA_MODEL_COPILOT_ROUTER=llama3.2

# ------- Dify (optional primary LLM) -------
DIFY_BASE_URL=https://api.dify.ai
DIFY_API_KEY=app-your-dify-app-api-key

# ------- Inngest (004 orchestration) -------
INNGEST_EVENT_KEY=local
INNGEST_SIGNING_KEY=signkey-local-dev-only-change-in-prod
INNGEST_DEV=1

# ------- Feature 004 bridge + worker -------
AI_CMO_REDIS_INNGEST_BRIDGE_ENABLED=true
MARKETING_EVENTS_STREAM_KEY=marketing:events
MARKETING_EVENTS_TOTAL_SHARDS=4
MARKETING_INNGEST_BRIDGE_GROUP=marketing:inngest-bridge

# ------- NextAuth + Enterprise SAML (V2.0) -------
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXT_PUBLIC_SAML_ENABLED=true
SAML_IDP_METADATA_URL=https://samltest.id/saml/idp
SAML_IDP_ENTITY_ID=https://samltest.id/saml/idp
SAML_SP_ENTITY_ID=http://localhost:3005
SAML_CLIENT_ID=nexus-saml-sp
SAML_CLIENT_SECRET=
SAML_CERT=
SAML_DEFAULT_AGENCY_SLUG=default-agency

# ------- Workspace (dev fallbacks) -------
NEXT_PUBLIC_DEFAULT_WORKSPACE_ID=your-workspace-uuid
NEXT_PUBLIC_USER_ID=your-user-uuid
DEV_PORT=3005
NEXT_PUBLIC_APP_URL=http://localhost:3005

# ------- Langfuse (optional observability) -------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ------- Security / Internal -------
INTERNAL_TOOL_SECRET=generate-a-long-random-string-min-32-chars
APPROVAL_HMAC_SECRET=generate-another-long-random-string-min-32-chars
CRON_SECRET=secret-for-vercel-cron-ai-eval

# ------- Publishing / 003 integrations (optional for full mesh) -------
PUBLISHING_ENABLED=true
ANALYTICS_SYNC_ENABLED=true
RAG_INGEST_ENABLED=true
AI_CMO_MV_REFRESH_ENABLED=true

# ------- App -------
NODE_ENV=development
APP_PORT=3005
