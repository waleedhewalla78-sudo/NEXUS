    "prepare:walkthrough": "powershell -ExecutionPolicy Bypass -File scripts/prepare-walkthrough.ps1",
    "walkthrough": "powershell -ExecutionPolicy Bypass -File scripts/full-walkthrough.ps1",
    "verify:local": "npm run typecheck && npm run test && npm run schema:verify && npm run walkthrough",
    "verify:staging": "npm run typecheck && npm run test && npm run schema:verify && npm run ai:verify",
    "verify:production": "tsx scripts/verify-production.ts all",
    "verify:production:code": "tsx scripts/verify-production.ts code",
    "verify:production:uat": "tsx scripts/verify-production.ts uat",
    "verify:production:deploy": "tsx scripts/verify-production.ts deploy",
    "otel:verify": "ts-node scripts/verify_otel.ts",
    "ci": "npm ci && npm run lint && npm test && npm run e2e:validate && npm run otel:verify"
