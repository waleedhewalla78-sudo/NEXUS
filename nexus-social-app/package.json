    "uat:postman-ab": "tsx scripts/run-postman-uat-ab.ts",
    "uat:human-gates": "powershell -ExecutionPolicy Bypass -File scripts/run-human-uat-gates.ps1",
    "uat:check-schema": "tsx scripts/check-uat-schema.ts",
