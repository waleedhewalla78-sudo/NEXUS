    "verify:v2-stack": "tsx scripts/verify-v2-stack.ts",
    "verify:inngest-cloud": "tsx scripts/verify-inngest-cloud.ts",
    "verify:ollama-agents": "tsx scripts/verify-ollama-agents.ts",
